# =============================================================================
# CadAgent .gitignore
# =============================================================================
# 上传到 Git: 所有源代码、文档、配置示例、资源文件
# 不上传: 运行时生成、环境配置、IDE设置、Python缓存
# =============================================================================

# -----------------------------------------------------------------------------
# 1. Python 运行时缓存
# -----------------------------------------------------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# -----------------------------------------------------------------------------
# 2. 环境配置 (含敏感信息)
# -----------------------------------------------------------------------------
.env
*.key
secrets/

# -----------------------------------------------------------------------------
# 3. IDE / 编辑器配置
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# 4. 操作系统文件
# -----------------------------------------------------------------------------
Thumbs.db
.DS_Store
desktop.ini
.Trash-*

# -----------------------------------------------------------------------------
# 5. CadAgent 运行时目录
# -----------------------------------------------------------------------------
log/*.log
snapshots/*.FCStd
sessions/*.json
snapshots/*/
sessions/*/
uploads/

# -----------------------------------------------------------------------------
# 6. 测试和覆盖率
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
*.cover

# -----------------------------------------------------------------------------
# 7. Claude Code (用户本地配置)
# -----------------------------------------------------------------------------
.claude/
docs/

# -----------------------------------------------------------------------------
# 8. 开发日志 (临时)
# -----------------------------------------------------------------------------
log.txt
log.md
*.log
/docs
CLAUDE.md
