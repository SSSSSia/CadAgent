# LLM API Configuration
# This plugin uses the OpenAI-compatible chat completions API.
# Any provider that supports this interface (with optional function calling) should work.

# --- Pick ONE provider and uncomment the corresponding block ---

# SiliconFlow (default)
API_BASE_URL=https://api.siliconflow.cn/v1
API_KEY=sk-your-api-key-here
MODEL_NAME=Pro/zai-org/GLM-5.1

# OpenAI
# API_BASE_URL=https://api.openai.com/v1
# API_KEY=sk-your-api-key-here
# MODEL_NAME=gpt-4o

# DeepSeek
# API_BASE_URL=https://api.deepseek.com/v1
# API_KEY=sk-your-api-key-here
# MODEL_NAME=deepseek-chat

# ZhipuAI (BigModel)
# API_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# API_KEY=your-api-key-here
# MODEL_NAME=glm-4-plus

# Local (Ollama / LMStudio / etc.)
# API_BASE_URL=http://localhost:11434/v1
# API_KEY=no-key-needed
# MODEL_NAME=qwen3:8b

# --- Optional ---

# Maximum output tokens per request (default: 4096)
# MAX_TOKENS=4096

# Vision Model (optional — leave empty to disable vision features)
# If using the same provider as main LLM, copy the URL and Key.
# VISION_API_BASE_URL=
# VISION_API_KEY=
# VISION_MODEL_NAME=

# --- Vision Provider Examples ---
# SiliconFlow: model=Pro/zai-org/GLM-4V-Plus
# DeepSeek:    model=deepseek-chat
# ZhipuAI:     model=glm-4v-plus
# Qwen:        model=qwen-vl-plus
# OpenAI:      model=gpt-4o
# Moonshot:    model=moonshot-v1-128k
# Local:       model=llava

# Vision model parameters (defaults shown)
# VISION_MAX_TOKENS=2048
# VISION_TEMPERATURE=0.3
# VISION_TIMEOUT=60
